                        const n = [...formData.players]; n[i].name = e.target.value;
                        setFormData({...formData, players: n});
                      }}
                    />
                    <input 
                      className="w-1/2 px-3 py-2 bg-white border rounded-lg text-sm" 
                      placeholder="UID In-game"
                      value={p.uid}
                      onChange={e => {
                        const n = [...formData.players]; n[i].uid = e.target.value;
                        setFormData({...formData, players: n});
                      }}
                    />
                  </div>
                ))}
             </div>
          </div>
        </section>

        {settings.isPaymentOn && (
          <section className="bg-white p-8 rounded-3xl border shadow-sm flex flex-col md:flex-row gap-8 items-center">
            <div className="flex flex-col items-center gap-2">
              <img src={settings.qrisUrl} className="w-48 h-48 border-4 border-slate-100 rounded-2xl" alt="QRIS" />
              <span className="text-[10px] font-bold text-slate-400 uppercase">Scan QRIS untuk Bayar</span>
            </div>
            <div className="space-y-4 flex-1 w-full">
              <h3 className="font-bold flex items-center gap-2"><CreditCard /> Bukti Pembayaran</h3>
              <p className="text-xs text-slate-500">Silakan unggah bukti transfer ke layanan hosting gambar (seperti Imgur/PostImage) dan masukkan link-nya di bawah ini.</p>
              <input 
                className="w-full px-4 py-3 bg-slate-50 border rounded-xl text-sm outline-none focus:ring-2 focus:ring-indigo-500"
                placeholder="https://imgur.com/bukti-bayar.jpg"
                value={formData.paymentProof}
                onChange={e => setFormData({...formData, paymentProof: e.target.value})}
              />
            </div>
          </section>
        )}
      </div>

      <div className="bg-white p-8 rounded-3xl border shadow-sm h-fit sticky top-24 space-y-6">
        <h3 className="font-black text-xl uppercase tracking-tighter border-b pb-4">Ringkasan Tim</h3>
        <ul className="space-y-3 text-sm font-medium text-slate-500">
          <li className="flex justify-between">Nama Tim: <span className="text-slate-900 truncate ml-4 font-bold">{formData.teamName || "-"}</span></li>
          <li className="flex justify-between">Total Pemain: <span className="text-slate-900 font-bold">{formData.players.filter(p=>p.name).length}</span></li>
          <li className="flex justify-between">Biaya Pendaftaran: <span className="text-indigo-600 font-black">Rp 50.000</span></li>
          <li className="flex justify-between">Bukti Bayar: <span>{formData.paymentProof ? <span className="text-green-600 font-bold">Terlampir</span> : <span className="text-red-400">Belum ada</span>}</span></li>
        </ul>
        <button 
          onClick={handleSubmit}
          disabled={isSubmitting || !formData.teamName || (settings.isPaymentOn && !formData.paymentProof)}
          className="w-full py-4 bg-indigo-600 text-white rounded-2xl font-black text-lg hover:bg-indigo-700 transition disabled:bg-slate-200 disabled:text-slate-400 shadow-xl shadow-indigo-200"
        >
          {isSubmitting ? "MENGIRIM..." : "SUBMIT SEKARANG"}
        </button>
        <p className="text-[10px] text-center text-slate-400 font-medium">Dengan menekan tombol, Anda menyetujui seluruh peraturan turnamen yang berlaku.</p>
      </div>
    </div>
  );
}

function AdminDashboard({ settings, registrations, db, appId }) {
  const [activeTab, setActiveTab] = useState('pendaftar');
  const [aiInsight, setAiInsight] = useState({});
  const [loadingAi, setLoadingAi] = useState(null);

  const getInsight = async (reg) => {
    setLoadingAi(reg.id);
    const prompt = `Berikan rangkuman singkat (1 kalimat) tentang tim "${reg.teamName}" yang mendaftar dengan ${reg.players.length} pemain. Apakah terlihat seperti tim yang siap bertanding?`;
    const res = await callGemini(prompt, "Kamu adalah analis administrasi turnamen.");
    setAiInsight(prev => ({ ...prev, [reg.id]: res }));
    setLoadingAi(null);
  };

  return (
    <div className="bg-white rounded-3xl border shadow-xl overflow-hidden min-h-[600px] animate-in zoom-in-95 duration-300">
      <div className="flex bg-slate-50 border-b">
        <button onClick={() => setActiveTab('pendaftar')} className={`px-8 py-4 font-bold text-sm transition ${activeTab === 'pendaftar' ? 'bg-white text-indigo-600 border-b-2 border-indigo-600' : 'text-slate-400 hover:text-slate-600'}`}>DAFTAR PENDAFTAR</button>
        <button onClick={() => setActiveTab('settings')} className={`px-8 py-4 font-bold text-sm transition ${activeTab === 'settings' ? 'bg-white text-indigo-600 border-b-2 border-indigo-600' : 'text-slate-400 hover:text-slate-600'}`}>PENGATURAN GLOBAL</button>
      </div>

      <div className="p-8">
        {activeTab === 'pendaftar' && (
          <div className="space-y-4">
            <div className="flex justify-between items-center mb-6">
               <h3 className="font-black text-2xl uppercase tracking-tighter">Manajemen Tim ({registrations.length})</h3>
               <div className="flex gap-2">
                  <span className="flex items-center gap-1 text-xs font-bold text-green-600 bg-green-50 px-3 py-1 rounded-full border border-green-100">
                    Confirmed: {registrations.filter(r=>r.status==='confirmed').length}
                  </span>
                  <span className="flex items-center gap-1 text-xs font-bold text-amber-600 bg-amber-50 px-3 py-1 rounded-full border border-amber-100">
                    Pending: {registrations.filter(r=>r.status==='pending').length}
                  </span>
               </div>
            </div>

            {registrations.length === 0 && (
              <div className="py-20 text-center text-slate-300">
                <Users size={48} className="mx-auto mb-4 opacity-20" />
                <p className="font-bold">Belum ada tim yang mendaftar.</p>
              </div>
            )}

            {registrations.map(reg => (
              <div key={reg.id} className="p-6 border rounded-3xl flex flex-col md:flex-row justify-between items-start md:items-center gap-6 bg-white hover:border-indigo-200 transition shadow-sm hover:shadow-md">
                <div className="flex items-center gap-4 flex-1">
                  <div className="relative">
                    <img src={reg.teamLogo || "https://via.placeholder.com/150"} className="w-16 h-16 rounded-2xl object-cover border bg-slate-50" alt="logo" />
                    {reg.status === 'confirmed' && (
                      <div className="absolute -top-2 -right-2 bg-green-500 text-white p-1 rounded-full border-2 border-white">
                        <CheckCircle size={12} />
                      </div>
                    )}
                  </div>
                  <div className="flex-1">
                    <h4 className="font-black text-xl uppercase tracking-tighter">{reg.teamName}</h4>
                    <p className="text-xs text-slate-400 font-bold uppercase tracking-widest">{reg.players.length} Pemain Utama</p>
                    
                    {aiInsight[reg.id] ? (
                      <div className="mt-2 text-xs text-indigo-600 bg-indigo-50/50 p-2 rounded-lg border border-indigo-100 flex items-start gap-2">
                        <Sparkles size={14} className="shrink-0 mt-0.5" />
                        <p className="italic">"{aiInsight[reg.id]}"</p>
                      </div>
                    ) : (
                      <button 
                        onClick={() => getInsight(reg)}
                        disabled={loadingAi === reg.id}
                        className="mt-2 flex items-center gap-1 text-[10px] font-black text-indigo-500 hover:text-indigo-700 transition"
                      >
                        <Zap size={12} /> {loadingAi === reg.id ? "MENILAI TIM..." : "TANYA ANALISIS AI ✨"}
                      </button>
                    )}
                  </div>
                </div>

                <div className="flex items-center gap-3 bg-slate-50 p-2 rounded-2xl border">
                  {reg.paymentProof && (
                    <button 
                      onClick={() => window.open(reg.paymentProof)} 
                      title="Lihat Bukti Bayar"
                      className="p-3 bg-white text-indigo-600 rounded-xl hover:bg-indigo-600 hover:text-white transition shadow-sm"
                    >
                      <CreditCard size={20}/>
                    </button>
                  )}
                  <button 
                    onClick={() => updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'registrations', reg.id), {status: 'confirmed'})} 
                    title="Konfirmasi Tim"
                    className="p-3 bg-white text-green-600 rounded-xl hover:bg-green-600 hover:text-white transition shadow-sm"
                  >
                    <CheckCircle size={20}/>
                  </button>
                  <button 
                    onClick={() => deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'registrations', reg.id))} 
                    title="Hapus / Tolak"
                    className="p-3 bg-white text-red-600 rounded-xl hover:bg-red-600 hover:text-white transition shadow-sm"
                  >
                    <Trash2 size={20}/></button>
                </div>
              </div>
            ))}
          </div>
        )}

        {activeTab === 'settings' && (
           <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div className="space-y-4">
                <label className="block text-xs font-black text-slate-400 uppercase tracking-widest">Aturan & Regulasi</label>
                <textarea 
                  className="w-full h-64 p-4 bg-slate-50 border rounded-2xl outline-none focus:ring-2 focus:ring-indigo-500 font-mono text-sm"
                  value={settings.rulesText}
                  placeholder="Masukkan poin-poin aturan turnamen..."
                  onChange={e => setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'settings', 'config'), { rulesText: e.target.value }, { merge: true })}
                />
                <p className="text-[10px] text-slate-400">Aturan ini akan digunakan oleh AI untuk membuat narasi promosi di halaman utama.</p>
              </div>
              <div className="space-y-6">
                <div className="space-y-2">
                  <label className="block text-xs font-black text-slate-400 uppercase tracking-widest">Link QRIS Pembayaran</label>
                  <input 
                    className="w-full p-4 bg-slate-50 border rounded-2xl outline-none focus:ring-2 focus:ring-indigo-500"
                    value={settings.qrisUrl}
                    placeholder="https://link-gambar-qris.jpg"
                    onChange={e => setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'settings', 'config'), { qrisUrl: e.target.value }, { merge: true })}
                  />
                </div>
                <div className="space-y-2">
                  <label className="block text-xs font-black text-slate-400 uppercase tracking-widest">Maksimal Slot Tim</label>
                  <input 
                    type="number"
                    className="w-full p-4 bg-slate-50 border rounded-2xl outline-none focus:ring-2 focus:ring-indigo-500"
                    value={settings.slotMax}
                    onChange={e => setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'settings', 'config'), { slotMax: parseInt(e.target.value) }, { merge: true })}
                  />
                </div>
                <div className="p-6 bg-amber-50 rounded-2xl border border-amber-100 flex gap-4">
                  <AlertTriangle className="text-amber-500 shrink-0" />
                  <div>
                    <p className="text-xs font-bold text-amber-800 uppercase mb-1">Peringatan Admin</p>
                    <p className="text-[11px] text-amber-700 leading-relaxed">Pastikan semua URL gambar yang dimasukkan menggunakan protokol HTTPS dan dapat diakses secara publik. Jika login Google gagal, pastikan domain diizinkan di Firebase Console.</p>
                  </div>
                </div>
              </div>
           </div>
        )}
      </div>
    </div>
  );
}
